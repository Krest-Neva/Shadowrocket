            except Exception: pass

            sys.stdout.write(f"    [!] попытка {attempt} не удалась, повтор через {int(1 + attempt*0.5)}s...\n")
            sys.stdout.flush()
            time.sleep(1 + attempt * 0.5)

        full_network_diagnostics()

        print("  [tor] Попытка через Tor...")
        if shutil.which('tor') and shutil.which('torsocks'):
            try:
                # Не запускаем tor, предполагаем что он уже запущен или torsocks работает без запуска
                lines = []
                proc = subprocess.run(
                    ["torsocks", "curl", "-s", "-L", url],
                    stdout=subprocess.PIPE,
                    stderr=subprocess.DEVNULL,
                    timeout=25
                )
                if proc.returncode == 0:
                    lines = proc.stdout.decode("utf-8", errors="ignore").splitlines()
                    if lines and len(lines) > 10 and not any("<html" in str(l).lower() for l in lines[:15]):
                        print("  [+] Успешно через Tor")
                        return lines, "torsocks curl"
            except Exception:
